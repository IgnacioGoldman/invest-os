BASE_CURRENCY=EUR

# Optional. Used for local-only total calculations when a source reports non-EUR values.
# Values mean: 1 unit of currency equals N units of BASE_CURRENCY.
# USD also covers USDT, USDC, and FDUSD if those stablecoin rates are omitted.
# Example: {"USD":0.8528,"GBP":1.17,"SEK":0.086}
FX_RATES_JSON={}

BINANCE_API_KEY=
BINANCE_API_SECRET=
# Start date for Binance deposit/withdrawal replay used by Refresh Binance ledger.
BINANCE_LEDGER_START_DATE=2025-08-18T15:07:00+00:00

IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Keeps the frontend useful if all real/manual data is empty.
ENABLE_DEMO_FALLBACK=true
MARKET_PRICE_STALE_HOURS=24
